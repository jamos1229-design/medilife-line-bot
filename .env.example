# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=ここにLINEチャネルアクセストークンを入力
LINE_CHANNEL_SECRET=ここにLINEチャネルシークレットを入力

# Anthropic Claude API
ANTHROPIC_API_KEY=ここにAnthropicのAPIキーを入力

# Zoom予約リンク（CalendlyなどのURL）
ZOOM_BOOKING_URL=https://calendly.com/your-link

# サーバーポート（Railway/Renderは自動設定されるので変更不要）
PORT=3000
