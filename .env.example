# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=ここにLINEチャネルアクセストークンを入力
LINE_CHANNEL_SECRET=ここにLINEチャネルシークレットを入力

# Anthropic Claude API
ANTHROPIC_API_KEY=ここにAnthropicのAPIキーを入力

# Zoom予約リンク（CalendlyなどのURL）
ZOOM_BOOKING_URL=https://calendly.com/your-link

# サーバーポート（Railway/Renderは自動設定されるので変更不要）
PORT=3000

# ─── Instagram 自動投稿 ───────────────────────────────────────────────────────
# InstagramビジネスアカウントのユーザーID（数字）
INSTAGRAM_USER_ID=ここにInstagramユーザーIDを入力

# FacebookページアクセストークンJページアクセストークン）
FACEBOOK_PAGE_ACCESS_TOKEN=ここにFacebookページアクセストークンを入力

# 投稿に使うデフォルト画像URL（公開アクセス可能なURL必須）
DEFAULT_IMAGE_URL=https://あなたの画像URL.jpg
